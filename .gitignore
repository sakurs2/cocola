# ---- OS ----
.DS_Store
Thumbs.db

# ---- Editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Env / Secrets ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Go ----
bin/
vendor/
*.test
*.out
coverage.txt
# Compiled service/CLI binaries dropped at an app root by `go build .`
/apps/admin-api/admin-api
/apps/admin-api/admin-mint
/apps/sandbox-manager/opensandbox-verify

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# ---- Node / TS ----
node_modules/
.next/
out/
.turbo/
.pnpm-store/
*.tsbuildinfo

# ---- Buf / Proto generated ----
# Generic build output dirs (per-app) stay ignored...
**/gen/
# ...but the shared proto stubs are committed: they ARE the cross-language
# API contract and are required for an out-of-the-box build (the codegen
# toolchain is non-trivial behind a corporate TLS proxy). See ADR-0002.
!packages/proto/gen/
!packages/proto/gen/**
packages/proto/gen/**/__pycache__/

# ---- Local data ----
.data/
# ignore tmp/ contents wholesale (scratch space, never committed).
# The multi-agent dev change-log now lives in docs/archive/ (a normal tracked
# directory), so tmp/ no longer needs any re-include exception.
tmp/
*.log

# run-stack.sh per-service logs (local dev stack)
.run-logs/

# real llm-gateway upstream config (contains your endpoint); keep only the .example
deploy/llm-config.json
.drawio-tmp
# M-minimal demo runtime data (sandbox volumes, never committed)
.cocola-data/

# Local Claude Code agent state (never committed)
.claude/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Env / Secrets ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Go ----
bin/
vendor/
*.test
*.out
coverage.txt

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# ---- Node / TS ----
node_modules/
.next/
out/
.turbo/
.pnpm-store/
*.tsbuildinfo

# ---- Buf / Proto generated ----
# Generic build output dirs (per-app) stay ignored...
**/gen/
# ...but the shared proto stubs are committed: they ARE the cross-language
# API contract and are required for an out-of-the-box build (the codegen
# toolchain is non-trivial behind a corporate TLS proxy). See ADR-0002.
!packages/proto/gen/
!packages/proto/gen/**
packages/proto/gen/**/__pycache__/

# ---- Local data ----
.data/
tmp/
*.log

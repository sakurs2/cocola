{
  "schema_version": 1,
  "runtime": "cocola-sandbox-runtime",
  "workspace": {
    "root": "/workspace",
    "outputs": "/workspace/outputs",
    "downloads": "/workspace/downloads",
    "session": "/session",
    "runtime_state": "/session/runtime",
    "cache": "/cache"
  },
  "profiles": {
    "coding": {
      "default_resources": {
        "cpu": "2000m",
        "memory": "4096Mi"
      },
      "services": {
        "code-server": {
          "enabled": true,
          "startup": "resident"
        }
      },
      "capabilities": {
        "browser": {
          "enabled": true,
          "startup": "on-demand"
        },
        "artifacts": {
          "enabled": true,
          "startup": "workspace-output"
        },
        "github": {
          "enabled": true,
          "startup": "run-scoped"
        },
        "preview": {
          "enabled": true,
          "startup": "on-demand-managed"
        }
      }
    },
    "minimal": {
      "default_resources": {
        "cpu": "500m",
        "memory": "512Mi"
      },
      "services": {
        "code-server": {
          "enabled": false,
          "startup": "disabled"
        }
      },
      "capabilities": {
        "browser": {
          "enabled": false,
          "startup": "disabled"
        },
        "artifacts": {
          "enabled": true,
          "startup": "workspace-output"
        },
        "github": {
          "enabled": false,
          "startup": "disabled"
        },
        "preview": {
          "enabled": true,
          "startup": "on-demand-managed"
        }
      }
    }
  },
  "services": {
    "code-server": {
      "supervisor_program": "code-server",
      "kind": "http",
      "port": 39378,
      "required": false
    }
  },
  "editor": {
    "kind": "code-server",
    "extensions_dir": "/opt/cocola/code-server/extensions",
    "extensions_lock": "/opt/cocola/code-server-extensions.lock.json",
    "language_tools_dir": "/opt/cocola/toolchains/bin",
    "update_policy": "runtime-image-only"
  },
  "capabilities": {
    "browser": {
      "kind": "on-demand",
      "runner": "/opt/cocola/browser-runner.js",
      "state_dir": "/session/runtime/browser/profile",
      "output_dir": "/workspace/outputs/browser",
      "required": false,
      "commands": ["inspect", "screenshot", "pdf"]
    },
    "artifacts": {
      "kind": "workspace-output",
      "output_dir": "/workspace/outputs",
      "html_preview": "isolated-self-contained",
      "required": true,
      "commands": ["status", "list"]
    },
    "github": {
      "kind": "run-scoped-broker",
      "cli": "/usr/local/bin/gh",
      "real_cli": "/opt/cocola/gh/current/bin/gh",
      "persistent_auth": false,
      "required": false,
      "commands": ["gh", "git"]
    },
    "preview": {
      "kind": "managed-user-process",
      "state_dir": "/session/runtime/cocola/previews",
      "required": false,
      "commands": ["start", "status", "stop", "logs"]
    }
  }
}

# ------------------------------------------------------------------ general
COCOLA_ENV=dev
COCOLA_LOG_LEVEL=info

# ------------------------------------------------------------------ postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cocola
POSTGRES_PASSWORD=cocola_dev_pw
POSTGRES_DB=cocola

# ------------------------------------------------------------------ redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------------ 附件对象存储(MinIO / S3,ADR-0017 P1a)
# 附件"真源":gateway 把每个上传文件 PutObject 进桶,再按阈值分流——小文件内联 +
# oss_key,大文件仅 oss_key;agent-runtime 对仅 oss_key 的附件代 pull 进沙箱。
# full.yml 已内置 minio + minio-init 两个节点,下列默认值即指向它;不设这些变量,
# gateway 保持 P0 纯内联(feature 默认 dark)。gateway / agent-runtime 同源命名。
# endpoint 用 host:port(不带 scheme);USE_SSL 仅当值恰为 "1" 时启用 HTTPS。
# COCOLA_MINIO_ENDPOINT=minio:9000
# COCOLA_MINIO_ACCESS_KEY=cocola
# COCOLA_MINIO_SECRET_KEY=cocola_dev_pw          # 支持 _FILE 间接(Vault,见下方鉴权段说明)
# COCOLA_MINIO_BUCKET=cocola
# COCOLA_MINIO_USE_SSL=                          # "1" 走 HTTPS;compose 网络内留空即可
# 小/大文件分流阈值(字节);留空 = 默认 16MiB(16*1024*1024)。必须可配置,不写死。
# COCOLA_ATTACHMENT_INLINE_MAX_BYTES=16777216
# 前端单次上传硬上限(字节),经 NEXT_PUBLIC_ 暴露给浏览器侧 adapter;这不是分流阈值,
# 而是「客户端内联 base64 走 JSON 请求体」能承载的上限。留空/非法回落 32MiB(高于 16MiB
# 分流阈值,保证内联/后端代 pull 两条路都能从 UI 触达)。注意 NEXT_PUBLIC_* 在构建期内联,
# 改它需重新 build web 镜像。
# NEXT_PUBLIC_ATTACHMENT_MAX_BYTES=33554432
# MinIO 根凭据 + 宿主端口(full.yml 起 minio 节点用;改凭据请同步上面 ACCESS/SECRET):
# COCOLA_MINIO_ROOT_USER=cocola
# COCOLA_MINIO_ROOT_PASSWORD=cocola_dev_pw
# COCOLA_MINIO_API_HOST_PORT=9000
# COCOLA_MINIO_CONSOLE_HOST_PORT=9001

# ------------------------------------------------------------------ 沙箱后端 / OpenSandbox
# docker-compose.full.yml 默认用 docker 后端(DooD)。要在全栈下验证 OpenSandbox 后端,
# 取消下面三行注释即可(无需任何 override 文件):
#   1) 先 `make opensandbox-up` 起本机 OpenSandbox server(宿主 :8090);
#   2) 设以下变量后 `docker compose -f deploy/docker-compose/docker-compose.full.yml up -d`。
# 注意 URL 要带 /v1 后缀;sandbox-manager 在 compose 网络内,经 host.docker.internal 访问
# 宿主上的 server(端口 = COCOLA_OPENSANDBOX_HOST_PORT,默认 8090)。
# COCOLA_SANDBOX_PROVIDER=opensandbox
# COCOLA_OPENSANDBOX_URL=http://host.docker.internal:8090/v1
# COCOLA_OPENSANDBOX_API_KEY=                       # server 开了 [server].api_key 才需要
# 可选:按需分配的资源下限(provider 对零值兜底,见 ADR-0015):
# COCOLA_OPENSANDBOX_DEFAULT_CPU=500m
# COCOLA_OPENSANDBOX_DEFAULT_MEMORY=512Mi

# ------------------------------------------------------------------ 宿主端口覆盖(可选)
# full.yml 所有宿主发布端口都可用下列变量覆盖(容器内监听端口与服务间互访不变)。
# 默认值已让 full 栈与 opensandbox 栈共存:admin-api 宿主端口默认 8092,把 8090 让给
# OpenSandbox server。一般无需改动。
# COCOLA_REDIS_HOST_PORT=6379
# COCOLA_PG_HOST_PORT=5432
# COCOLA_SANDBOX_HOST_PORT=50051
# COCOLA_LLM_HOST_PORT=18091
# COCOLA_ADMIN_HOST_PORT=8092          # 注意:默认 8092,不是 8090(避让 OpenSandbox)
# COCOLA_AGENT_HOST_PORT=50061
# COCOLA_GATEWAY_HOST_PORT=8080
# COCOLA_WEB_HOST_PORT=3000
# COCOLA_OPENSANDBOX_HOST_PORT=8090    # docker-compose.opensandbox.yml 的 server 宿主端口

# ------------------------------------------------------------------ 系统定时任务(admin-api)
# 管理员创建的系统任务默认随 admin-api worker 执行；初版限制最短调度间隔 1 小时。
# COCOLA_SCHEDULER_ENABLED=true
# COCOLA_AGENT_ADDR=127.0.0.1:50061
# COCOLA_GATEWAY_URL=http://127.0.0.1:8080
# COCOLA_SCHEDULER_POLL_SECS=60
# COCOLA_SCHEDULER_RUN_TIMEOUT_SECS=3600
# COCOLA_SCHEDULER_HEARTBEAT_SECS=30
# COCOLA_SCHEDULER_LEASE_TIMEOUT_SECS=300
# COCOLA_SCHEDULER_MIN_INTERVAL_SECS=3600

# ------------------------------------------------------------------ 全链路鉴权
# gateway / agent-runtime / llm-gateway 三方共享的 HS256 密钥。run-stack.sh 缺省
# 用 local-dev-secret；真实测试建议改成你自己的随机串(三处会自动取同一个值)。
COCOLA_AUTH_SECRET=local-dev-secret
#
# 机密文件间接(*_FILE,生产/Vault 用) —— 任意 COCOLA_* 机密都支持「文件优先」:
# 若设了同名 + _FILE 的变量,程序优先读该文件内容(去尾换行),否则回落到本 env。
# 这样 Vault Agent / CSI / Docker secret 把机密渲染成文件后,只需:
#   COCOLA_AUTH_SECRET_FILE=/vault/secrets/auth_secret
# 应用零感知 Vault。dev 不设 _FILE 即用上面的明文 env,行为与现状逐字一致。
# 部署样例见 deploy/k8s/06-vault-secrets.yaml 与 docs/runbook/secrets-vault.md。

# ------------------------------------------------------------------ llm 上游(你购买的模型服务)
# 接入真实模型分两步:
#   1) 让 run-stack.sh 拉起 llm-gateway 并接到真实上游(下面这些变量);
#   2) make up-all  (会自动 source 本仓库根目录的 .env)
#
# 你的服务是 Anthropic 兼容,所以选 anthropic provider。两种配法二选一:
#
# --- 配法 A:纯环境变量(单模型,最快) ---
COCOLA_LLM_PROVIDER=anthropic
COCOLA_ANTHROPIC_BASE_URL=https://你购买服务的域名   # ← 填你的 url(SDK 会在其后追加 /v1/messages)
COCOLA_ANTHROPIC_API_KEY=sk-ant-xxxx                # ← 填你的真实密钥(本文件已被 .gitignore 忽略)
COCOLA_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022   # 真实模型名;纯 env 下它同时充当别名
COCOLA_ANTHROPIC_STREAM=true                        # SSE 流式;若上游流式接口异常(接受请求但不吐字节导致对话卡住),改 false 走非流式回退
#
# --- 配法 B:配置文件(多模型/自定义定价/别名与真实模型解耦,推荐用于全链路测试) ---
# 复制 deploy/llm-config.example.json -> deploy/llm-config.json,改其中 base_url,然后:
# COCOLA_LLM_CONFIG=deploy/llm-config.json
# COCOLA_ANTHROPIC_API_KEY=sk-ant-xxxx              # 密钥仍只走环境变量,绝不写进配置文件
#
# 可选:周期 token 配额(0 或留空 = 不限)
# COCOLA_QUOTA_USER_DAILY_TOKENS=0
# COCOLA_QUOTA_TENANT_MONTHLY_TOKENS=0

# ------------------------------------------------------------------ 启动模式
# 本文件只服务源码开发入口 `make dev`：cocola 服务原生运行，本地
# k3d/OpenSandbox 与基础设施容器化。正式部署由 `cocola install` 生成独立的
# ~/.cocola/config.env，不读取仓库开发配置，也不存在 COCOLA_ENV 模式开关。

# ------------------------------------------------------------------ 本地基础设施
# make dev 会以固定的宿主地址和本地开发凭据准备 PostgreSQL、Redis、MinIO；
# 无需在这里重复配置 POSTGRES_* / REDIS_*。外接基础设施时使用统一的
# COCOLA_PG_DSN、COCOLA_REDIS_ADDR、COCOLA_MINIO_*。
# COCOLA_PG_DSN=postgres://cocola:password@127.0.0.1:5432/cocola?sslmode=disable
# COCOLA_REDIS_ADDR=127.0.0.1:6379
# COCOLA_LLM_REDIS_URL=redis://127.0.0.1:6379/0

# 浏览器访问 Cocola 的完整 Origin 白名单（协议 + host + 可选端口，不含路径）。
# Web 在签发 Preview WebSocket runtime token 前做精确校验；sandbox-manager 从
# 同一配置派生 code-server trusted-origins。禁止使用 `*`；生产必须改为真实域名。
COCOLA_PUBLIC_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ------------------------------------------------------------------ 附件对象存储(MinIO / S3,ADR-0017 P1a)
# 附件"真源":gateway 把每个上传文件 PutObject 进桶,再按阈值分流——小文件内联 +
# oss_key,大文件仅 oss_key;agent-runtime 对仅 oss_key 的附件代 pull 进沙箱。
# dev 启动脚本会准备 MinIO 并注入可用默认值。只有绕过脚本、单独启动服务且
# 不设这些变量时，gateway 才退化为纯内联。gateway / agent-runtime 同源命名。
# endpoint 用 host:port(不带 scheme);USE_SSL 仅当值恰为 "1" 时启用 HTTPS。
# COCOLA_MINIO_ENDPOINT=minio:9000
# COCOLA_MINIO_ACCESS_KEY=cocola
# COCOLA_MINIO_SECRET_KEY=cocola_dev_pw          # 支持 _FILE 间接(Vault,见下方鉴权段说明)
# COCOLA_MINIO_BUCKET=cocola
# COCOLA_MINIO_USE_SSL=                          # "1" 走 HTTPS;compose 网络内留空即可
# 小/大文件分流阈值(字节);留空 = 默认 16MiB(16*1024*1024)。必须可配置,不写死。
# COCOLA_ATTACHMENT_INLINE_MAX_BYTES=16777216
# 前端单次上传硬上限(字节),经 NEXT_PUBLIC_ 暴露给浏览器侧 adapter;这不是分流阈值,
# 而是「客户端内联 base64 走 JSON 请求体」能承载的上限。留空/非法回落 32MiB(高于 16MiB
# 分流阈值,保证内联/后端代 pull 两条路都能从 UI 触达)。注意 NEXT_PUBLIC_* 在构建期内联,
# 改它需重新 build web 镜像。
# NEXT_PUBLIC_ATTACHMENT_MAX_BYTES=33554432
# MinIO 根凭据（本地 dev 基础设施使用；改凭据请同步上面 ACCESS/SECRET）：
# COCOLA_MINIO_ROOT_USER=cocola
# COCOLA_MINIO_ROOT_PASSWORD=cocola_dev_pw
# COCOLA_MINIO_API_HOST_PORT=9000
# COCOLA_MINIO_CONSOLE_HOST_PORT=9001

# ------------------------------------------------------------------ 沙箱后端 / OpenSandbox
# 默认沙箱后端为 OpenSandbox。`make dev` 会准备本地 k3d/Helm OpenSandbox
# runtime；直接运行内层 dev stack 时也可使用 docker-compose.opensandbox.yml。
# 注意 URL 要带 /v1 后缀。
# COCOLA_OPENSANDBOX_URL=http://host.docker.internal:8090/v1
# COCOLA_OPENSANDBOX_API_KEY=                       # server 开了 [server].api_key 才需要
# COCOLA_OPENSANDBOX_HTTP_TIMEOUT=240s              # lifecycle HTTP 请求超时
# COCOLA_OPENSANDBOX_EXEC_TIMEOUT=5m                # 单次 sandbox Exec 默认超时;长截图可调成 10m
# Sandbox Runtime Profile 由运维统一选择，不由 Agent/对话覆盖：
# coding 默认启用 Code Server 与按需 Browser，资源下限 2000m/4096Mi；minimal 默认关闭
# 两项能力，资源下限 500m/512Mi。可显式设置能力开关覆盖 Profile 默认值。
COCOLA_SANDBOX_PROFILE=coding
# COCOLA_CODE_SERVER_ENABLED=true
# COCOLA_BROWSER_ENABLED=true
# 可选:覆盖所选 Profile 的按需分配资源下限(provider 对零值兜底,见 ADR-0015):
# COCOLA_OPENSANDBOX_DEFAULT_CPU=2000m
# COCOLA_OPENSANDBOX_DEFAULT_MEMORY=4096Mi

# 每个新 Session 的 local-path PVC 请求容量；默认 2Gi，属于软容量请求而非硬配额。
# Admin -> Settings 可热更新数据库覆盖，只影响之后新建的 Session。
# COCOLA_SESSION_VOLUME_SIZE=2Gi
# COCOLA_SESSION_STORAGE_ROOT=/var/lib/cocola/storage

# ------------------------------------------------------------------ Agent 长任务执行策略
# Agent Run 不设置总 wall-clock 超时；每次模型请求和单个工具步骤分别受限。
# 下列前两个值可由 Admin -> Settings 热覆盖，修改后作用于下一个新 Run。
# COCOLA_AGENT_MAX_TURNS=200
# COCOLA_AGENT_TOOL_STEP_TIMEOUT_SECS=600
# Sandbox 内的用户 token 默认有效 7 天，用于覆盖多小时任务；修改后需重启 gateway。
# COCOLA_SANDBOX_TOKEN_TTL_SECONDS=604800

# 沙箱镜像发布到 GHCR 后,单机快速部署可用 latest 拉最新成功构建;生产建议
# 使用 digest-pinned 引用,避免 tag 被覆盖后集群拉到不可预期内容。
# COCOLA_SANDBOX_IMAGE=ghcr.io/sakurs2/cocola-sandbox-runtime:latest
# COCOLA_SANDBOX_IMAGE=ghcr.io/sakurs2/cocola-sandbox-runtime:sha-<commit>@sha256:<digest>

# 本地 OpenSandbox 端口（外层 k3d port-forward 或内层 Docker server 使用）。
# COCOLA_OPENSANDBOX_HOST_PORT=8090

# ------------------------------------------------------------------ 系统定时任务(admin-api)
# 首次启动默认启用；运行中由 Admin -> Settings 的 scheduler.enabled 热更新。
# worker loop 始终存在，关闭设置只暂停 due-task 扫描。初版限制最短间隔 1 小时。
# COCOLA_SCHEDULER_ENABLED=true
# COCOLA_AGENT_ADDR=127.0.0.1:50061
# COCOLA_GATEWAY_URL=http://127.0.0.1:8080
# COCOLA_SCHEDULER_POLL_SECS=60
# COCOLA_SCHEDULER_RUN_TIMEOUT_SECS=3600
# COCOLA_SCHEDULER_HEARTBEAT_SECS=30
# COCOLA_SCHEDULER_LEASE_TIMEOUT_SECS=300

# ------------------------------------------------------------------ 全链路鉴权
# 以下值让 `cp .env.example .env` 后的本地 dev/prod 栈可以直接登录和调用。
# 它们都是公开的本地开发凭据；任何真实部署都必须全部替换为随机强密钥和密码。
# gateway / admin-api / llm-gateway 共享的 HS256 密钥。
COCOLA_AUTH_SECRET=local-dev-secret
AUTH_SECRET=local-dev-auth-secret
COCOLA_ADMIN_KEY=local-dev-admin-key
# 首次启动创建管理员；false 表示账号已存在时不重置密码。
COCOLA_BOOTSTRAP_ADMIN_USERNAME=admin
COCOLA_BOOTSTRAP_ADMIN_EMAIL=admin@cocola.local
COCOLA_BOOTSTRAP_ADMIN_PASSWORD=cocola-admin
COCOLA_BOOTSTRAP_ADMIN_RESET=false
# 加密 Admin -> Models 中的模型 API key。生产必须保持稳定，否则历史密文无法解密。
COCOLA_MODEL_SECRET_KEY=cocola-local-model-secret
# 加密管理员配置里的其他敏感字段(MCP env/header 等)。
COCOLA_CONFIG_SECRET_KEY=cocola-local-config-secret
#
# 机密文件间接(*_FILE,生产/Vault 用) —— 任意 COCOLA_* 机密都支持「文件优先」:
# 若设了同名 + _FILE 的变量,程序只读该文件内容(去尾换行)；文件不可读则启动失败。
# 这样 Vault Agent / Docker secret 把机密渲染成文件后,只需:
#   COCOLA_AUTH_SECRET_FILE=/vault/secrets/auth_secret
# 应用零感知 Vault。dev 不设 _FILE 即用上面的明文 env,行为与现状逐字一致。

# ------------------------------------------------------------------ LLM 模型
# Provider、endpoint、API key、模型路由和默认模型统一在 Admin -> Models 中管理，
# 持久化到 Postgres。这里不再提供同义的文件/env 模型配置，避免进程间配置漂移。
# LLM Gateway 每 2 秒检查一次目录变更；没有配置模型时明确拒绝请求，不回退 Fake。
# 下列是进程启动级可靠性参数，修改后需要重启 llm-gateway：
# 单次模型请求最大耗时；修改后需要重启 llm-gateway。
# COCOLA_LLM_TIMEOUT_SECS=600
# COCOLA_LLM_MAX_RETRIES=2
# COCOLA_LLM_RATE_LIMIT_RPS=0
#
# 可选:周期 token 配额(0 或留空 = 不限)
# COCOLA_QUOTA_USER_DAILY_TOKENS=0
# COCOLA_QUOTA_TENANT_MONTHLY_TOKENS=0
